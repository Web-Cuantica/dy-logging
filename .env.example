# Identidad del servicio (aparecen como atributos en cada log)
SERVICE_NAME=my-service
NODE_ENV=production
APP_VERSION=1.4.2

# Nivel de log. Si no se define, se usa el default por ambiente:
#   local/dev -> debug | qa/staging/uat -> info | prod -> info
# Valores validos: trace, debug, info, warn, error, fatal, silent
LOG_LEVEL=info
